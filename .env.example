# ---- Discord ----
DISCORD_TOKEN=your-bot-token
APP_ID=your-application-id
GUILD_ID=your-server-id
# Optional: restrict /process to one channel (the screenshots channel). Blank = any channel.
CHANNEL_ID=

# ---- Gemini (vision extraction) ----
# NOTE: this is a TEMPLATE — never put a real key here (this file is meant to be
# shared/committed). Put your real key in .env instead.
GEMINI_API_KEY=your-gemini-key
# A rolling alias so the model can't be retired out from under you. Pin a specific
# one (e.g. gemini-2.5-flash-lite, gemini-3.5-flash) only if you want to.
GEMINI_MODEL=gemini-flash-latest

# ---- Google Sheets ----
# Path to the service-account key file (see SETUP.md)
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# The long id in the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
SPREADSHEET_ID=
SHEET_NAME=Activity Points

# ---- Extraction tuning ----
# gemini = always Gemini vision (recommended for these screenshots — names are
#          stylized/CJK/decorated, which OCR can't read reliably)
# hybrid = Tesseract OCR first, Gemini only for images OCR can't read
# ocr    = never Gemini (English names only)
EXTRACTION_MODE=gemini
# A row is OCR-accepted when its name fuzzy-matches a roster IGN at or above this (0-1)
OCR_ACCEPT_SCORE=0.75
# An image falls back to Gemini when fewer than this many rows were OCR-accepted
MIN_ROWS_PER_IMAGE=5
# Ignore images older than this many hours when scanning the channel
MAX_IMAGE_AGE_HOURS=48

# ---- Reactions on each screenshot message (optional) ----
# Unicode by default. For a custom server emote, use its id or "name:id".
EMOJI_PROCESSING=⏳
EMOJI_DONE=✅
EMOJI_FAILED=❌
